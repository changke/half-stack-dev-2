{
  "name": "half-stack-dev",
  "version": "3.0.0",
  "description": "My blog powered by StaticNext",
  "scripts": {
    "lint:css": "stylelint \"src/main/webapp/{css,modules}/**/*.css\"",
    "lint:ts": "eslint . data src/main/webapp",
    "lint": "npm run lint:css && npm run lint:ts",
    "typecheck": "tsc --noEmit",
    "build:clean": "sn-build clean",
    "build:copy": "sn-build copy",
    "build:markdown": "sn-build markdown2",
    "build:prototype": "sn-build prototype2",
    "build:scripts": "sn-build scripts",
    "build:styles": "sn-build styles",
    "build": "sn-build dev",
    "build:prod": "sn-build prod",
    "test": "wtr",
    "serve": "wds",
    "all:local": "npm run lint && npm run typecheck && npm run test && npm run build",
    "all:server": "npm run lint && npm run typecheck && npm run test && npm run build:prod"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "keywords": [
    "blog"
  ],
  "author": "@changke",
  "license": "ISC",
  "devDependencies": {
    "@changke/staticnext-build": "^0.26.1",
    "@eslint/js": "^9.39.1",
    "@open-wc/testing": "^4.0.0",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/mocha": "^10.0.10",
    "@web/dev-server": "^0.4.6",
    "@web/dev-server-esbuild": "^1.0.4",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-puppeteer": "^0.18.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "sinon": "^21.0.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  },
  "dependencies": {
    "@catppuccin/highlightjs": "^1.0.1",
    "@changke/staticnext-lib": "^1.13.0",
    "lit": "^3.3.1",
    "lit-html": "^3.3.1"
  }
}
