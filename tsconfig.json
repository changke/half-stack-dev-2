{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "lib": ["ES2024", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "./src",
    "target": "ES2024",
    "types": ["mocha"],
    "verbatimModuleSyntax": true
  },
  "include": ["src/main/webapp/**/*.ts"]
}
